<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Life_Insurance_1.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3341"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="Kaggle" custom_title="0" dock_id="1" table="4,6:mainKaggle"/><dock_state state="000000ff00000000fd00000001000000020000054800000401fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000005480000013900ffffff000002580000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="Kaggle" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="12" mode="1"/></sort><column_widths><column index="1" value="69"/><column index="2" value="69"/><column index="3" value="69"/><column index="4" value="71"/><column index="5" value="30"/><column index="6" value="92"/><column index="7" value="92"/><column index="8" value="92"/><column index="9" value="101"/><column index="10" value="97"/><column index="11" value="62"/><column index="12" value="151"/><column index="13" value="124"/><column index="14" value="190"/><column index="15" value="105"/><column index="16" value="78"/><column index="17" value="127"/><column index="18" value="70"/><column index="19" value="58"/><column index="20" value="68"/><column index="21" value="47"/><column index="22" value="47"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT
    CASE
        WHEN Premium = '-' OR CAST(Premium AS REAL) = 0 THEN 'Missing / Zero Premium'
        ELSE 'Positive Premium'
    END AS premium_status,
    COUNT(*) AS total_policies,
    SUM(CASE
            WHEN &quot;POLICY STATUS&quot; IN ('Lapse', 'Surrender')
            THEN 1 ELSE 0
        END) AS underperforming_policies,
    ROUND(
        100.0 * SUM(CASE
                        WHEN &quot;POLICY STATUS&quot; IN ('Lapse', 'Surrender')
                        THEN 1 ELSE 0
                    END) / COUNT(*),
        2
    ) AS underperforming_pct
FROM kaggle
GROUP BY premium_status;

</sql><current_tab id="0"/></tab_sql></sqlb_project>
